---
import HeroButtons from "./HeroButtons.astro";
---

<section id="home" class="hero">

  <img
    src="/pit.png"
    alt="Compassion Bridge Initiative Uganda"
    class="hero-bg"
  />

  <div class="overlay"></div>

  <div class="container hero-content">

    <span class="welcome">
      COMPASSION BRIDGE INITIATIVE UGANDA
    </span>

    <h1>
      Restoring Dignity.<br>
      Building Futures.
    </h1>

    <p>

      We empower vulnerable children, women and communities through
      education, health promotion, sustainable livelihoods, child
      protection and compassionate community development across Uganda.

    </p>

    <HeroButtons />

  </div>

</section>

<style>

.hero{

position:relative;

height:100vh;

display:flex;

align-items:center;

justify-content:center;

overflow:hidden;

margin-top:95px;

}

.hero-bg{

position:absolute;

top:0;

left:0;

width:100%;

height:100%;

object-fit:cover;

}

.overlay{

position:absolute;

top:0;

left:0;

width:100%;

height:100%;

background:linear-gradient(
90deg,
rgba(10,35,70,.88),
rgba(10,35,70,.65),
rgba(10,35,70,.35)
);

}

.hero-content{

position:relative;

z-index:2;

color:white;

max-width:720px;

}

.welcome{

display:inline-block;

padding:10px 22px;

border-radius:40px;

background:rgba(212,160,23,.18);

border:1px solid rgba(212,160,23,.6);

font-size:14px;

font-weight:700;

letter-spacing:2px;

margin-bottom:25px;

}

.hero h1{

font-size:72px;

line-height:1.08;

margin-bottom:30px;

font-weight:800;

}

.hero p{

font-size:22px;

line-height:1.8;

max-width:650px;

}

@media(max-width:900px){

.hero{

height:auto;

padding:140px 0 90px;

text-align:center;

}

.hero-content{

max-width:100%;

}

.hero h1{

font-size:42px;

}

.hero p{

font-size:18px;

}

}

</style>